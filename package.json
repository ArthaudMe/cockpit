{
  "name": "cockpit",
  "version": "0.1.0",
  "description": "Pilot your company — desktop cockpit with AI co-pilot",
  "author": "Emdash",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --port 3939",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "next build && node scripts/prepare-standalone.js && electron-builder",
    "electron:start": "electron .",
    "electron:publish": "pnpm release:mac:publish",
    "oauth:check": "node scripts/release/check-oauth-proxy.js",
    "release:mac": "pnpm oauth:check && next build && node scripts/prepare-standalone.js && electron-builder --mac --publish never && node scripts/release/notarize-mac.js",
    "release:mac:verify": "node scripts/release/notarize-mac.js --skip-submit",
    "release:mac:publish": "pnpm release:mac && node scripts/release/upload-github.js",
    "lint": "next lint"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.25.2",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "cross-env": "^10.1.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "next": "^15.3.3",
    "postcss": "^8.5.0",
    "posthog-js": "^1.364.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.cockpit.app",
    "productName": "Cockpit",
    "directories": {
      "output": "dist-electron"
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*"
    ],
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "identity": "Arthaud mesnard (9BXV462SP6)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 160,
          "y": 170
        },
        {
          "x": 380,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "ArthaudMe",
      "repo": "cockpit"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Utility"
    }
  },
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp",
      "protobufjs",
      "core-js",
      "electron-winstaller"
    ]
  }
}
