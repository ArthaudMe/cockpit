# Cockpit environment variables
# Copy this file to .env.local and fill in the values.
# Ask the person who invited you for the credentials.

# Shared secret for the OAuth token-exchange proxy (proxy/).
# REQUIRED for builds — inlined at build time; must match PROXY_SECRET
# configured on the deployed proxy (Vercel). Generate: openssl rand -hex 32
OAUTH_PROXY_SECRET=

# Google (Calendar + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Linear
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Notion
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Optional: Notion internal integration token (fallback if OAuth not set up)
# NOTION_INTERNAL_TOKEN=
