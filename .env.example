# Cockpit environment variables
# Copy this file to .env.local and fill in the values.
# Ask the person who invited you for the credentials.

# OAuth token-exchange proxy (proxy/). Set both to enable proxy-backed OAuth.
# Leave both blank for direct local OAuth credentials during development.
OAUTH_PROXY_URL=https://proxy-mio-xyz.vercel.app

# Shared secret for the OAuth token-exchange proxy.
# REQUIRED when OAUTH_PROXY_URL is set — inlined at build time; must match
# PROXY_SECRET configured on the deployed proxy (Vercel).
# Generate: openssl rand -hex 32
OAUTH_PROXY_SECRET=

# Google (Calendar + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Linear
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Notion
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Optional: Notion internal integration token (fallback if OAuth not set up)
# NOTION_INTERNAL_TOKEN=
